  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: 'Cuando empieces el juego haz un swipe a la izquierda (espero que sepas
    cual es).


    Un grid con una llave bajara. Lo que tienes que hacer es tocar
    las casillas donde haya parte de la llave.


    Cuando hayas seleccionado todas
    las casillas, haz un swipe hacia arriba. Si lo hiciste bien, abrira la puerta
    y vuelve a hacer un swipe a la izquierda.


    Si, por otro lado, te equivocaste,
    puedes volver a tocar la casilla para deseleccionarla.


    Tienes 1 minuto
    para abrir cuantas puertas puedas.'
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 0fb3fbc62b4502546b89638a9daee731, type: 2}
